---
interface Props {
  label: string;
  description?: string;
  id?: string;
}

const { label, description, id = "" } = Astro.props;
---

<section class="section" {id}>
  <div class="section-header">
    <span class="section-label">{label}</span>
    {description && <span class="section-desc">{description}</span>}
  </div>
  <slot />
</section>

<style>
  .section {
    padding: 2.5rem 2rem;
    border-bottom: 0.5px solid var(--border);
    max-width: 720px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.08em;
    display: inline;
    white-space: nowrap;
  }

  .section-desc {
    font-size: 11px;
    color: #a89f94;
    line-height: 1.5;
  }
</style>

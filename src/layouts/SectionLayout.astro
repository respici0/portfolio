---
interface Props {
  name: string;
  id?: string;
}

const { name, id = "" } = Astro.props;
---

<section class="section" {id}>
  <h2 class="section-label">{name}</h2>
  <slot />
</section>

<style>
  .section {
    padding: 2.5rem 2rem;
    border-bottom: 0.5px solid var(--border);
    max-width: 720px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    display: block;
  }
</style>

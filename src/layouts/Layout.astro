---
import Analytics from "@vercel/analytics/astro";
import MatrixTheme from "./MatrixTheme.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>respicio.dev</title>
    <Analytics />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #f9f6f2;
        --bg-white: #ffffff;
        --hero-name: #4a7a5c;
        --text: #1a1a1a;
        --muted: #6b6560;
        --subtle: #a89f94;
        --border: #e0d9cf;
        --chip-bg: #f4efe8;
        --accent: #c97d3a;
        --accent-bg: #fbf3e8;
        --accent-hover: #b36a2a;
        --accent-dark: #854f0b;
        --github-color: #24292f;
        --linkedIn-color: #0a66c2;
        --font-sans: "Inter", sans-serif;
        --font-mono: "JetBrains Mono", monospace;
        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 12px;
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: 50px;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        transition:
          background-color 0.8s ease,
          color 0.8s ease;
      }

      .mono {
        font-family: var(--font-mono);
      }
      .muted {
        color: var(--muted);
      }
      .accent {
        color: var(--accent);
      }

      .page {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .divider {
        border: none;
        border-top: 0.5px solid var(--border);
      }
    </style>

    <style is:global>
      nav,
      footer,
      .section,
      .hero {
        transition: border-color 0.8s ease;
      }
      a,
      p,
      h1,
      h2,
      h3,
      span {
        transition: color 0.8s ease;
      }

      .hero-name {
        color: #3d5c4a;
        transition: color 0.8s ease;
      }

      .rabbit-btn {
        background: none;
        border: none;
        padding: 0;
        display: inline-flex;
        align-items: center;
        transition: opacity 0.25s;
        cursor: pointer;
      }

      #nav-typewriter {
        background: #000000;
        padding: 0 6px;
        border-radius: 3px;
        font-family: var(--font-mono);
        font-weight: 400;
        color: #00ff41;
        transition:
          background 0.8s ease,
          color 0.8s ease;
      }

      #footer-typewriter {
        background: #000000;
        padding: 0 5px;
        border-radius: 3px;
        align-items: center;
        gap: 0;
      }
    </style>
  </head>

  <body>
    <MatrixTheme />

    <slot />
  </body>
</html>

---
import Analytics from "@vercel/analytics/astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>respicio.dev</title>
    <Analytics />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: #f9f6f2;
        --bg-white: #ffffff;
        --hero-name: #4a7a5c;
        --text: #1a1a1a;
        --muted: #6b6560;
        --subtle: #a89f94;
        --border: #e0d9cf;
        --chip-bg: #f4efe8;
        --accent: #c97d3a;
        --accent-bg: #fbf3e8;
        --accent-hover: #b36a2a;
        --accent-dark: #854f0b;
        --github-color: #24292f;
        --linkedIn-color: #0a66c2;
        --font-sans: "Inter", sans-serif;
        --font-mono: "JetBrains Mono", monospace;
        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 12px;
      }

      body.matrix-mode {
        --bg: #000000;
        --bg-white: #0a0a0a;
        --text: #00ff41;
        --muted: #008f11;
        --subtle: #005500;
        --border: #003b00;
        --chip-bg: #001200;
        --accent: #00cc33;
        --accent-hover: #00ff41;
        --accent-dark: #00cc33;
        --github-color: #00ff41;
        --linkedIn-color: #00ff41;
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: 50px;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        transition:
          background-color 0.8s ease,
          color 0.8s ease;
      }

      .mono {
        font-family: var(--font-mono);
      }
      .muted {
        color: var(--muted);
      }
      .accent {
        color: var(--accent);
      }

      .page {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .divider {
        border: none;
        border-top: 0.5px solid var(--border);
      }
    </style>

    <style is:global>
      nav,
      footer,
      .section,
      .hero {
        transition: border-color 0.8s ease;
      }
      a,
      p,
      h1,
      h2,
      h3,
      span {
        transition: color 0.8s ease;
      }

      .hero-name {
        color: #3d5c4a;
        transition: color 0.8s ease;
      }
      body.matrix-mode .hero-name {
        color: #00ff41;
      }

      .rabbit-btn {
        background: none;
        border: none;
        padding: 0;
        display: inline-flex;
        align-items: center;
        opacity: 0.4;
        transition: opacity 0.25s;
        cursor: pointer;
      }

      #rabbit-header .rabbit-svg {
        display: inline-flex;
        align-items: center;
      }
      #rabbit-header .pill-svg {
        display: none;
        align-items: center;
      }

      body.matrix-mode #rabbit-header .rabbit-svg {
        display: none;
      }
      body.matrix-mode #rabbit-header .pill-svg {
        display: inline-flex;
      }

      #rabbit-connect .rabbit-svg {
        display: inline-flex;
        align-items: center;
      }
      #rabbit-connect .pill-svg {
        display: none;
        align-items: center;
      }

      body.matrix-mode #rabbit-connect .rabbit-svg {
        display: none;
      }
      body.matrix-mode #rabbit-connect .pill-svg {
        display: inline-flex;
      }

      body.matrix-mode #rabbit-connect {
        display: none;
      }

      #matrix-overlay {
        position: fixed;
        inset: 0;
        background: #000;
        z-index: 1000;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.8s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      #matrix-overlay.visible {
        opacity: 1;
        pointer-events: all;
      }

      #matrix-canvas {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 1.2s ease;
      }

      #matrix-canvas.visible {
        opacity: 1;
      }

      #typewriter-wrap {
        position: relative;
        z-index: 10;
        text-align: center;
        padding: 2rem;
      }

      #typewriter-text {
        font-family: "JetBrains Mono", monospace;
        font-size: clamp(14px, 2vw, 18px);
        color: #00ff41;
        line-height: 1.8;
        opacity: 1;
        transition: opacity 0.8s ease;
        white-space: pre;
      }

      #typewriter-text.fade-out {
        opacity: 0;
      }

      .tw-cursor {
        display: inline-block;
        width: 2px;
        height: 1.1em;
        background: #00ff41;
        margin-left: 2px;
        vertical-align: text-bottom;
        animation: blink 0.7s step-end infinite;
      }

      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0;
        }
      }
    </style>
  </head>

  <body>
    <div id="matrix-overlay">
      <canvas id="matrix-canvas"></canvas>
      <div id="typewriter-wrap">
        <div id="typewriter-text">
          <span id="tw-content"></span>
          <span class="tw-cursor"></span>
        </div>
      </div>
    </div>

    <slot />

    <script>
      const COPY: Record<string, string> = {
        connect:
          "Robert has been searching for you.\nNone of this is real.\nBut you are...\nIt's time to wake up...\n",
      };

      let matrixActive = false;
      let matrixMode = false;
      let animFrame: number | null = null;
      let twTimeout: ReturnType<typeof setTimeout> | null = null;

      const canvas = document.getElementById(
        "matrix-canvas",
      ) as HTMLCanvasElement;
      const ctx = canvas.getContext("2d")!;
      const CHARS =
        "ｦｧｨｩｪｫｬｭｮｯｰｱｲｳｴｵｶｷｸｹｺｻｼｽｾｿﾀﾁﾂﾃﾄﾅﾆﾇﾈﾉﾊﾋﾌﾍﾎﾏﾐﾑﾒﾓﾔﾕﾖﾗﾘﾙﾚﾛﾜﾝ0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
      const FONT_SIZE = 14;
      let drops: number[] = [];

      function initCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        drops = Array(Math.floor(canvas.width / FONT_SIZE))
          .fill(1)
          .map(() => Math.random() * -50);
      }

      function drawMatrix() {
        if (!matrixActive) return;
        ctx.fillStyle = "rgba(0,0,0,0.05)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        for (let i = 0; i < drops.length; i++) {
          const char = CHARS[Math.floor(Math.random() * CHARS.length)];
          const b = Math.random();
          ctx.fillStyle =
            b > 0.95 ? "#FFFFFF" : b > 0.7 ? "#00FF41" : "#008F11";
          ctx.font = `${FONT_SIZE}px 'JetBrains Mono', monospace`;
          ctx.fillText(char, i * FONT_SIZE, drops[i] * FONT_SIZE);
          if (drops[i] * FONT_SIZE > canvas.height && Math.random() > 0.975)
            drops[i] = 0;
          drops[i] += 0.5;
        }
        animFrame = requestAnimationFrame(drawMatrix);
      }

      function typewrite(text: string, onDone: () => void) {
        const el = document.getElementById("tw-content")!;
        el.textContent = "";
        let i = 0;
        function next() {
          if (i >= text.length) {
            twTimeout = setTimeout(onDone, 2800);
            return;
          }
          const ch = text[i++];
          el.textContent += ch;
          let delay = 110;
          if (ch === ".") delay = 600;
          else if (ch === "?") delay = 400;
          else if (ch === ",") delay = 250;
          else if (ch === "\n") delay = 900;
          else if (ch === " ") delay = 80;
          twTimeout = setTimeout(next, delay);
        }
        next();
      }

      function triggerEgg(source: string) {
        if (matrixActive || matrixMode) return;
        matrixActive = true;
        initCanvas();

        const overlay = document.getElementById("matrix-overlay")!;
        overlay.classList.add("visible");

        setTimeout(() => {
          typewrite(COPY[source], () => {
            const tw = document.getElementById("typewriter-text")!;
            tw.classList.add("fade-out");

            setTimeout(() => {
              tw.style.display = "none";
              canvas.classList.add("visible");
              drawMatrix();

              setTimeout(() => {
                document.body.classList.add("matrix-mode");
                matrixMode = true;
              }, 1200);

              setTimeout(() => {
                overlay.classList.remove("visible");
                setTimeout(() => {
                  matrixActive = false;
                  if (twTimeout) clearTimeout(twTimeout);
                  if (animFrame) cancelAnimationFrame(animFrame);
                  ctx.clearRect(0, 0, canvas.width, canvas.height);
                  canvas.classList.remove("visible");
                  tw.classList.remove("fade-out");
                  tw.style.display = "";
                  const twContent = document.getElementById("tw-content");
                  if (twContent) twContent.textContent = "";

                  const navBtn = document.getElementById(
                    "rabbit-header",
                  ) as HTMLElement | null;
                  if (navBtn && matrixMode) {
                    navBtn.style.opacity = "1";
                    navBtn.removeAttribute("title");
                    navBtn.removeAttribute("aria-label");
                  }

                  const footerBtn = document.getElementById(
                    "rabbit-connect",
                  ) as HTMLElement | null;
                  if (footerBtn && matrixMode) {
                    footerBtn.style.opacity = "1";
                    footerBtn.removeAttribute("title");
                    footerBtn.removeAttribute("aria-label");
                  }
                }, 900);
              }, 4000);
            }, 800);
          });
        }, 900);
      }

      function exitMatrix() {
        if (!matrixMode) return;
        document.body.classList.remove("matrix-mode");
        matrixMode = false;

        const navBtn = document.getElementById(
          "rabbit-header",
        ) as HTMLElement | null;
        if (navBtn) {
          navBtn.style.opacity = "0.4";
          navBtn.setAttribute("title", "Follow the white rabbit");
          navBtn.setAttribute("aria-label", "Follow the white rabbit");
        }

        const footerBtn = document.getElementById(
          "rabbit-connect",
        ) as HTMLElement | null;
        if (footerBtn) {
          footerBtn.style.opacity = "0.4";
          footerBtn.setAttribute(
            "title",
            "...and see how far the rabbit hole goes. Take the red pill.",
          );
          footerBtn.setAttribute(
            "aria-label",
            "...and see how far the rabbit hole goes. Take the red pill.",
          );
        }
      }

      document.addEventListener("DOMContentLoaded", () => {
        const headerRabbit = document.getElementById(
          "rabbit-header",
        ) as HTMLElement | null;
        if (headerRabbit) {
          headerRabbit.style.opacity = "0.4";
          headerRabbit.addEventListener("click", () => {
            if (matrixMode) exitMatrix();
          });
        }

        const connectRabbit = document.getElementById(
          "rabbit-connect",
        ) as HTMLElement | null;
        if (connectRabbit) {
          connectRabbit.style.opacity = "0.4";
          connectRabbit.addEventListener("click", () => {
            if (matrixMode) {
              exitMatrix();
              return;
            }
            if (matrixActive) return;
            connectRabbit.style.opacity = "1";
            setTimeout(() => triggerEgg("connect"), 120);
          });
        }
      });

      window.addEventListener("resize", () => {
        if (matrixActive) initCanvas();
      });
    </script></body
  >
</html>

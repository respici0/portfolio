---
import SectionLayout from "../layouts/SectionLayout.astro";

type Stack = {
  skill: string;
  level: "primary" | "proficient" | "growing";
};

const stack: Stack[] = [
  { skill: "TypeScript", level: "primary" },
  { skill: "Next.js", level: "primary" },
  { skill: "SvelteKit", level: "primary" },
  { skill: "AWS", level: "primary" },
  { skill: "REST API", level: "primary" },
  { skill: "Tailwind CSS", level: "primary" },
  { skill: "Node.js", level: "proficient" },
  { skill: "Connect RPC", level: "proficient" },
  { skill: "Vite", level: "proficient" },
  { skill: "Vercel", level: "proficient" },
  { skill: "TanStack Query", level: "proficient" },
  { skill: "Vitest", level: "proficient" },
  { skill: "Astro", level: "growing" },
  { skill: "MongoDB", level: "growing" },
  { skill: "SST", level: "growing" },
];
---

<SectionLayout
  label="// stack"
  description="ok fine, here's the stack."
  id="stack"
>
  <p class="section-label">// stack</p>
  <div class="stack-grid">
    {
      stack.map(({ skill, level }: Stack) => (
        <div class="stack-item">
          <span class="stack-name">{skill}</span>
          <span class={`stack-level ${level}`}>{level}</span>
        </div>
      ))
    }
  </div>

  <style>
    .stack-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    @media (min-width: 768px) {
      .stack-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .stack-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 1rem;
      background: var(--bg-white);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-md);
    }

    .stack-name {
      font-size: 13px;
    }

    .stack-level {
      font-family: var(--font-mono);
      font-size: 10px;
    }

    .stack-level.primary {
      color: var(--accent);
    }
    .stack-level.proficient {
      color: var(--muted);
    }
    .stack-level.growing {
      color: var(--subtle);
    }
  </style>
</SectionLayout>

---
import WhiteRabbit from "./icons/WhiteRabbit.astro";
---

<footer class="footer-note">
  <a href="#" class="top-cta">↑ back to top</a>
  <p>
    I collaborated with Claude on the visual direction for my portfolio. Read
    about the process ↗
  </p>
  <div class="footer-note-wrapper">
    · Built with Astro · © 2026
    <button
      id="rabbit-connect"
      class="rabbit-btn"
      aria-label="...and see how far the rabbit hole goes."
      title="...and see how far the rabbit hole goes."
    >
      <WhiteRabbit />
    </button>
  </div>
</footer>

<style>
  .footer-note {
    text-align: center;
    padding: 1rem 2rem;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    max-width: 720px;
    margin: 0 auto;
  }

  .footer-note-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }

  .footer-note p {
    padding: 0;
    margin: 0;
  }
  .top-cta {
    text-decoration: none;
    display: block;
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .top-cta:hover {
    color: var(--accent-hover);
  }
</style>

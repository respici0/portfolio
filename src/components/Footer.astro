---
import WhiteRabbit from "./icons/WhiteRabbit.astro";
import BluePill from "./icons/BluePill.astro";
import RedPill from "./icons/RedPill.astro";
import Typewriter from "./Typewriter.astro";
---

<footer class="footer-note">
  <a href="#" class="top-cta">↑ back to top</a>
  <p>
    I collaborated with Claude on the visual direction for my portfolio. <button id="read-process-btn" class="read-process-btn">Read about the process ↗</button>
  </p>
  <div class="footer-note-wrapper">
    <span id="footer-static">
      · Built with Astro · © 2026
      <button
        id="rabbit-connect"
        class="rabbit-btn"
        style="vertical-align: middle; margin-left: 2px;"
      >
        <span class="footer-rabbit-icons">
          <span class="rabbit-svg">
            <WhiteRabbit />
          </span>
          <span class="pill-svg">
            <BluePill />
          </span>
        </span>
      </button>
    </span>

    <Typewriter type="footer" />

    <button
      id="red-pill-btn"
      class="rabbit-btn"
      style="opacity:0;pointer-events:none;transition:opacity 0.8s ease;vertical-align:middle;margin-left:6px;"
    >
      <RedPill />
    </button>
  </div>
</footer>

<style>
  .footer-note {
    text-align: center;
    padding: 1rem 2rem;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    max-width: 720px;
    margin: 0 auto;
  }

  .footer-note-wrapper {
    text-align: center;
    text-decoration: none;
  }

  .footer-note p {
    padding: 0;
    margin: 0;
  }
  .top-cta {
    text-decoration: none;
    display: block;
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .top-cta:hover {
    color: var(--accent-hover);
  }

  .read-process-btn {
    all: unset;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    cursor: pointer;
  }

  .read-process-btn:hover {
    color: var(--accent-hover);
  }
</style>

<script>
  document.getElementById("read-process-btn")?.addEventListener("click", () => {
    document.dispatchEvent(new CustomEvent("open-case-study", { detail: { id: "portfolio" } }));
  });
</script>

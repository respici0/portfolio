---
import SectionLayout from "../layouts/SectionLayout.astro";

const corePrinciples: string[] = [
  "I care about two kinds of users, the people using the product and the developers building it. Better DevX means better systems, and better systems turn complexity into great UX.",
  "I'd rather write thoughtful, readable, self documenting code. When the code is clear, performance stops being an afterthought and starts being part of good design.",
  "Ambiguity doesn't stop me. I ask questions, make my best call, and adjust when needed.",
  "When something catches my attention I get curious and focused. I need to understand the why, not just the how.",
  "I do my best work when I stay in flow. I value human connection but most things don't need a meeting to get there.",
  "I'll speak up early if something isn't technically feasible.",
  "I don't know everything and I'm okay with that. If there is a better solution, I'd love to hear it. That's how I grow and how we build better things together.",
  "I'm human. I make mistakes, I own them and learn from them.",
];
---

<SectionLayout
  label="// how i think"
  description="a peek inside my brain."
  id="think"
>
  {
    corePrinciples.map((principle: string, index: number) => {
      const order = String(index + 1).padStart(2, "0");
      return (
        <div class="how-item">
          <span class="how-num">{order}</span>
          <p>{principle}</p>
        </div>
      );
    })
  }
</SectionLayout>

<style>
  .how-item {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 0.5px solid var(--border);
  }

  .how-item:last-child {
    border-bottom: none;
  }

  .how-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    min-width: 24px;
    padding-top: 3px;
    flex-shrink: 0;
  }

  .how-item p {
    font-size: 14px;
    line-height: 1.7;
  }
</style>

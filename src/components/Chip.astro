---
interface Props {
  value: string;
  variant: "white" | "off-white";
}

const { value, variant } = Astro.props;
---

<span class="chip" data-variant={variant}>{value}</span>

<style>
  .chip {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    border: 0.5px solid #e0d9cf;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }

  .chip[data-variant="white"] {
    background: var(--bg-white);
  }
  .chip[data-variant="off-white"] {
    background: var(--chip-bg);
  }
</style>

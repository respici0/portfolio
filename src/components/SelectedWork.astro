---
import SectionLayout from "../layouts/SectionLayout.astro";
import Chip from "./Chip.astro";

type Project = {
  title: string;
  description: string;
  links: {
    type: "case study" | "case study in progress" | "live" | "github";
    url?: string;
  }[];
  tech: string[];
};

type Projects = {
  tag: "Fetch Rewards" | "Tensoriot" | "Eleveight" | "Personal Projects";
  year?: string;
  projects: Project[];
};

const projects: Projects[] = [
  {
    tag: "Fetch Rewards",
    year: "2022 - 2025",
    projects: [
      {
        title: "Campaign Management Dashboard",
        description:
          "Owned frontend architecture from scratch. Turned a multi-department campaign setup into a self-service workflow which dropped launch times from days to minutes.",
        links: [
          {
            type: "case study in progress",
          },
        ],
        tech: [
          "sveltekit",
          "typescript",
          "vite",
          "vitest",
          "tailwind",
          "shadcn",
          "rest api",
          "connect rpc",
          "protobuf",
          "okta auth",
          "sst",
          "aws",
        ],
      },
    ],
  },
  {
    tag: "Tensoriot",
    year: "2019 - 2022",
    projects: [
      {
        title: "Real-time Translator",
        description:
          "Designed and built a translation tool for a Canadian client — French Canadian to English and back, powered by AWS Translate.",
        links: [
          {
            type: "case study in progress",
          },
        ],
        tech: ["react", "websockets", "mui", "aws"],
      },
      {
        title: "Smart Store Analytics Dashboard",
        description:
          "Drove the frontend for a smart store analytics dashboard that surfaced consumer dwell time (heat maps) and purchase patterns (charts) across store sections.",
        links: [
          {
            type: "case study in progress",
          },
        ],
        tech: [
          "sveltekit",
          "typescript",
          "vite",
          "vitest",
          "tailwind",
          "shadcn",
          "rest api",
          "connect rpc",
          "protobuf",
          "okta auth",
          "sst",
          "aws",
        ],
      },
    ],
  },
  {
    tag: "Eleveight",
    year: "2018 - 2019",
    projects: [
      {
        title: "Case management platform",
        description:
          "Built a case management platform serving students, job seekers, schools, and social service organizations.",
        links: [
          {
            type: "case study in progress",
          },
        ],
        tech: ["react", "typescript", "websockets", "mui", "rest api", "aws"],
      },
    ],
  },
  {
    tag: "Personal Projects",
    projects: [
      {
        title: "respicio.dev",
        description:
          "My portfolio designed in collaboration with Claude, built entirely by me. The design process itself became a case study.",
        links: [
          {
            type: "case study in progress",
          },
          {
            type: "github",
            url: "https://github.com/respici0/portfolio",
          },
        ],
        tech: [
          "astro",
          "typescript",
          "vanilla js",
          "vanilla css",
          "vercel",
          "claude (ui/ux designer)",
        ],
      },
      {
        title: "Next Steps",
        description:
          "Full-stack with a friend. Auth, data layer, and UI built from the ground up. Features I wanted for the job search.",
        links: [
          {
            type: "case study in progress",
          },
          {
            type: "live",
            url: "https://next-steps-amber.vercel.app",
          },
          {
            type: "github",
            url: "https://github.com/respici0/portfolio",
          },
        ],
        tech: [
          "Next.js",
          "typescript",
          "tailwind",
          "server actions",
          "better auth",
          "mongodb",
          "mongoose",
          "vercel",
        ],
      },
    ],
  },
];
---

<SectionLayout
  label="// selected work"
  description="curated, not exhaustive."
  id="work"
>
  <!-- <div class="project-row" onclick="toggleCaseStudy('fetch')"> -->
  {
    projects.map(({ tag, year, projects }: Projects) => (
      <div class="project-group">
        <div class="project-header">
          <span class="project-tag">{tag}</span>
          {year && <span class="project-year">{year}</span>}
        </div>
        {/* PROJECTS */}
        {projects.map(({ title, description, links, tech }: Project) => (
          <div class="project-item">
            <div class="project-info">
              <div>
                <p class="project-title">{title}</p>
                <p class="project-desc">{description}</p>
              </div>
              <div class="links">
                {links.map(({ type, url }) =>
                  type === "case study" ? (
                    <button class="project-link" id="case-study">
                      case study ↗
                    </button>
                  ) : type === "case study in progress" ? (
                    <span class="project-coming-soon">{type}</span>
                  ) : (
                    <a class="project-link" href={url} target="_blank">
                      {type} ↗
                    </a>
                  ),
                )}
              </div>
            </div>
            <div class="tech">
              {tech.map((value) => (
                <Chip variant="white" {value} />
              ))}
            </div>
          </div>
        ))}
      </div>
    ))
  }
</SectionLayout>

<style>
  .project-group {
    border-bottom: 0.5px solid var(--border);
  }

  .project-group:last-child {
    border-bottom: none;
  }

  .project-item {
    padding: 0.875rem 0 0.875rem 1rem;
    border-top: 0.5px solid var(--border);
  }

  .project-info {
    display: flex;
    flex-direction: column-reverse;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.75rem;
  }

  .project-row {
    padding: 1.5rem 0;
    border-bottom: 0.5px solid var(--border);
    cursor: pointer;
  }

  .project-row:last-child {
    border-bottom: none;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.6rem;
  }

  .project-meta-left {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .project-meta-right {
    display: flex;
    flex-direction: column;
    align-items: end;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
  }
  span.project-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--chip-bg);
    color: var(--accent-dark);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }

  span.project-year {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }

  .divider {
    padding: 0.875rem 0 0.875rem 1rem;
    border-top: 0.5px solid var(--border);
  }

  .tech {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .links {
    display: flex;
    gap: 2rem;
    margin-bottom: 0.5em;
    justify-content: space-between;
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    text-decoration: none;
    cursor: pointer;
    border: none;
    background: none;
    padding: 0;
  }

  .project-coming-soon {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    text-decoration: none;
    border: none;
    background: none;
    padding: 0;
    opacity: 0.5;
  }

  .project-link:hover {
    color: var(--accent-hover);
  }

  .project-title {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.4rem;
  }

  .project-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  .chip-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  @media (min-width: 768px) {
    .project-info {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.75rem;
    }
    .links {
      flex-direction: column;
      align-items: flex-end;
      flex-shrink: 0;
      padding-left: 2rem;
      padding-top: 2px;
      gap: 0;
      margin-bottom: 0;
    }
  }
</style>

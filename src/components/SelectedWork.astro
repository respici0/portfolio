---
import {  type Company, type Project } from '../data/selectedWork/selectedWork'
import SectionLayout from "../layouts/SectionLayout.astro";
import CaseStudy from "./CaseStudy.astro";
import Chip from "./Chip.astro";

interface Props {
  companies: Company[]
}

const { companies } = Astro.props;
---

<SectionLayout
  label="// selected work"
  description="curated, not exhaustive."
  id="work"
>
  {
    companies.map(({ tag, year, projects }: Company) => (
      <div class="project-group">
        <div class="project-header">
          <span class="project-tag">{tag}</span>
          {year && <span class="project-year">{year}</span>}
        </div>
        {/* PROJECTS */}
        {projects.map(({ projectId, title, description, links, tech }: Project) => (
          <>
            <div class="project-item">
              <div class="project-info">
                <div>
                  <p class="project-title">{title}</p>
                  <p class="project-desc">{description}</p>
                </div>
                <div class="links">
                  {links.map(({ type, url }) =>
                    type === "case study" ? (
                      <button
                        class="project-link"
                        id={`${projectId}-trigger`}
                        data-project-id={`${projectId}`}
                      >
                        case study ↗
                      </button>
                    ) : type === "case study in progress" ? (
                      <span class="project-coming-soon">{type}</span>
                    ) : (
                      <a class="project-link" href={url} target="_blank">
                        {type} ↗
                      </a>
                    ),
                  )}
                </div>
              </div>
              <div class="tech">
                {tech.map((value) => (
                  <Chip variant="white" {value} />
                ))}
              </div>
            </div>
            {links.some(({ type }) => type === "case study") && <CaseStudy {projectId} />}
          </>
        ))}
      </div>
    ))
  }
</SectionLayout>

<style>
  .project-group {
    border-bottom: 0.5px solid var(--border);
  }

  .project-group:last-child {
    border-bottom: none;
  }

  .project-item {
    padding: 0.875rem 0 0.875rem 1rem;
    border-top: 0.5px solid var(--border);
  }

  .project-item.cs-open {
    background: var(--bg-white);
    border: 0.5px solid var(--border);
    border-bottom: none;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    padding-right: 1rem;
  }

  .project-info {
    display: flex;
    flex-direction: column-reverse;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.75rem;
  }

  .project-row {
    padding: 1.5rem 0;
    border-bottom: 0.5px solid var(--border);
    cursor: pointer;
  }

  .project-row:last-child {
    border-bottom: none;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.6rem;
  }

  .project-meta-left {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .project-meta-right {
    display: flex;
    flex-direction: column;
    align-items: end;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
  }
  span.project-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--chip-bg);
    color: var(--accent-dark);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
  }

  span.project-year {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }

  .divider {
    padding: 0.875rem 0 0.875rem 1rem;
    border-top: 0.5px solid var(--border);
  }

  .tech {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .links {
    display: flex;
    gap: 2rem;
    margin-bottom: 0.5em;
    justify-content: space-between;
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    text-decoration: none;
    cursor: pointer;
    border: none;
    background: none;
    padding: 0;
  }

  .project-coming-soon {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    text-decoration: none;
    border: none;
    background: none;
    padding: 0;
    opacity: 0.5;
  }

  .project-link:hover {
    color: var(--accent-hover);
  }

  .project-title {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    margin: 0 0 0.4rem;
  }

  .project-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  .chip-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  @media (min-width: 768px) {
    .project-info {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.75rem;
    }
    .links {
      flex-direction: column;
      align-items: flex-end;
      flex-shrink: 0;
      padding-left: 2rem;
      padding-top: 2px;
      gap: 0;
      margin-bottom: 0;
    }
  }
</style>

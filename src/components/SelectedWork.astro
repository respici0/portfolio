---
import SectionLayout from "../layouts/SectionLayout.astro";
import Chip from "./Chip.astro";

type Project = {
  title: string;
  year: string;
  tag: string;
  description: string;
  links: {
    type: "case study" | "live";
    url?: string;
  }[];
  tech: string[];
};

const projects: Project[] = [
  {
    title: "Campaign Management Dashboard",
    year: "2022 - 2024",
    tag: "Fetch Rewards",
    description: "Owned frontend architecture from scratch. Campaign launch time dropped from days to minutes — zero regressions at go-live.",
    links: [
      {
        type: "case study",
      },
    ],
    tech: [
      "sveltekit", "typescript", "google auth", "rest api", "connect rpc", "protobuf", "tailwindcss", "sst", "aws",
    ],
  },
];
---

<SectionLayout label="// selected work" description="curated, not exhaustive." id="work">
  <!-- <div class="project-row" onclick="toggleCaseStudy('fetch')"> -->
   {projects.map(({ title, year, tag, description, links, tech }: Project) => (
    <div class="project-row">
    <div class="project-meta">
      <div class="project-meta-left">
        <span class="tag">{tag}</span>
        <span class="project-year">{year}</span>
      </div>
      <div class="project-meta-right">
      {
        links.map(({type, url}) => (
          type === 'case study' ?
         <button class="project-link" id="fetch-toggle">{type} ↗</button> 
         : 
         <a href={url} target="_blank" class="project-link">{type} ↗</a>
        ))
      }
      </div>
    </div>
    <p class="project-title">{title}</p>
    <p class="project-desc">
      {description}
    </p>
    <div class="chip-row">
      {tech.map((value) => (<Chip {value} variant="white"/>))}
    </div>


---
import type { AstroComponentFactory } from "astro/runtime/server/render/astro/index.js";
import SectionLayout from "../layouts/SectionLayout.astro";
import Github from "./icons/Github.astro";
import LinkedIn from "./icons/LinkedIn.astro";

type Link = {
  href: string;
  cls: string;
  "aria-label": string;
  icon: AstroComponentFactory;
};

const links: Link[] = [
  {
    href: "https://github.com/respici0",
    cls: "github",
    "aria-label": "Github",
    icon: Github,
  },
  {
    href: "https://linkedin.com/in/respici0",
    cls: "linkedIn",
    "aria-label": "LinkedIn",
    icon: LinkedIn,
  },
];
---

<SectionLayout label="// let's connect" id="connect">
  <h3>and build something wonderful.</h3>
  <p>
    I'm open to full-time roles. If something looks interesting, I'd love to
    hear about it.
  </p>
  <div class="link-cta">
    <a href="mailto:respicio.robert@gmail.com" class="connect-email"
      >say hello ↗</a
    >
    <div style="width:0.5px;height:20px;background:#b9b3ab;"></div>
    <div style="display:flex;gap:1rem;align-items:center;"></div>
    {
      links.map(({ href, cls, "aria-label": label, icon: Icon }: Link) => (
        <a {href} target="_blank" class={cls} aria-label={label}>
          <Icon />
        </a>
      ))
    }
  </div>
</SectionLayout>

<style>
  h3 {
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .connect-email {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
    text-decoration: none;
  }

  .connect-email:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }

  .link-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .github,
  .linkedIn {
    color: var(--muted);
    display: flex;
    align-items: center;
  }

  .github:hover {
    color: var(--github-color);
  }

  .linkedIn:hover {
    color: var(--linkedIn-color);
  }
</style>

---
import { caseStudies } from "../data/selectedWork/caseStudies";

interface Props {
  projectId: string;
}

const { projectId } = Astro.props;
const caseStudy = caseStudies[projectId as keyof typeof caseStudies];
if (!caseStudy) return;
---

<div class="cs-wrapper">
  <div class="case-study" id={`case-study-${projectId}`}>
    <div class="cs-meta-grid">
      <div class="cs-meta-card">
        <span class="cs-meta-label">ROLE</span>
        <span class="cs-meta-value">{caseStudy.meta.role.value}</span>
        <span class="cs-meta-sub">{caseStudy.meta.role.sub}</span>
      </div>
      <div class="cs-meta-card">
        <span class="cs-meta-label">STACK</span>
        <span class="cs-meta-value">{caseStudy.meta.stack.value}</span>
        <span class="cs-meta-sub">{caseStudy.meta.stack.sub}</span>
      </div>
      <div class="cs-meta-card">
        <span class="cs-meta-label">OUTCOME</span>
        <span class="cs-meta-value">{caseStudy.meta.outcome.value}</span>
        <span class="cs-meta-sub">{caseStudy.meta.outcome.sub}</span>
      </div>
    </div>

    <div class="cs-body">
      <span class="section-label">// the problem</span>
      {caseStudy.problem.map((p) => <p>{p}</p>)}
    </div>

    <div class="before-after">
      <div class="ba-card">
        <span class="ba-label before">BEFORE</span>
        {
          caseStudy.beforeAfter.before.map((item) => (
            <div class="ba-item">
              <>
                <div class="ba-dot before" />
                <p>{item}</p>
              </>
            </div>
          ))
        }
      </div>
      <div class="ba-arrow">→</div>
      <div class="ba-card">
        <span class="ba-label after">AFTER</span>
        {
          caseStudy.beforeAfter.after.map((item) => (
            <div class="ba-item after">
              <>
                <div class="ba-dot after" />
                <p>{item}</p>
              </>
            </div>
          ))
        }
      </div>
    </div>

    {
      caseStudy.screenshot && (
        <div class="cs-body">
          <span class="section-label">// screenshot</span>
          <div class="screenshot-placeholder">
            <div class="screenshot-icon">
              <div class="screenshot-icon-inner" />
            </div>
            <p class="screenshot-caption">{caseStudy.screenshot.caption}</p>
            <p class="screenshot-desc">
              {caseStudy.screenshot.description
                .split("\n")
                .map((line, i, arr) => (
                  <>
                    {line}
                    {i < arr.length - 1 && <br />}
                  </>
                ))}
            </p>
          </div>
        </div>
      )
    }

    <div class="cs-body">
      <span class="section-label">// the hard parts</span>
      {
        caseStudy.hardParts.map((part, i) => (
          <div class="hard-part">
            <span class="hard-part-num">{String(i + 1).padStart(2, "0")}</span>
            <div>
              <h4>{part.title}</h4>
              {Array.isArray(part.description) ? (
                part.description.map((item) => <p>{item}</p>)
              ) : (
                <p>{part.description}</p>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <div class="cs-outcome">
      <span class="section-label">// outcome</span>
      <h3>{caseStudy.outcome.heading}</h3>
      <p>{caseStudy.outcome.body}</p>
    </div>

    {
      caseStudy.thoughts && (
        <div class="cs-thoughts">
          <span class="section-label">// thoughts</span>
          {caseStudy.thoughts.map((thoughts) => (
            <p>{thoughts}</p>
          ))}
        </div>
      )
    }

    <div class="cs-close-row">
      <button class="cs-close-btn" data-project-id={projectId}>↑ close</button>
    </div>
  </div>
</div>

<style>
  .case-study {
    display: none;
    background: var(--bg-white);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    margin-top: 1rem;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .case-study.open {
    display: block;
    border-top: 0.5px solid var(--border);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    margin-top: 0;
  }

  .cs-close-row {
    display: flex;
    justify-content: center;
    padding: 0.75rem 2rem;
    border-top: 0.5px solid var(--border);
  }

  .cs-close-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .cs-close-btn:hover {
    color: var(--accent-hover);
  }

  .cs-meta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
    padding: 1.5rem 2rem;
    border-bottom: 0.5px solid var(--border);
  }

  @media (min-width: 768px) {
    .cs-meta-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .cs-meta-card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
  }

  .cs-meta-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  .cs-meta-value {
    display: block;
    font-size: 13px;
    font-weight: 500;
  }

  .cs-meta-sub {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 3px;
  }

  .cs-body {
    padding: 1.75rem 2rem;
    border-bottom: 0.5px solid var(--border);
  }

  .cs-body p {
    font-size: 14px;
    line-height: 1.8;
    max-width: 560px;
  }

  .cs-body p + p {
    margin-top: 0.75rem;
  }

  .section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  /* before/after */
  .before-after {
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
    padding: 1.75rem 2rem;
    border-bottom: 0.5px solid var(--border);
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .before-after {
      grid-template-columns: minmax(0, 1fr) 32px minmax(0, 1fr);
      gap: 0;
    }
  }

  .ba-card {
    background: var(--bg-white);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
  }

  .ba-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    margin-bottom: 10px;
  }

  .ba-label.before {
    color: #a32d2d;
  }
  .ba-label.after {
    color: #3b6d11;
  }

  body.matrix-mode .ba-label.before {
    color: var(--subtle);
  }
  body.matrix-mode .ba-label.after {
    color: var(--accent);
  }

  .ba-item {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .ba-item:last-child {
    margin-bottom: 0;
  }

  .ba-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .ba-dot.before {
    background: var(--border);
  }
  .ba-dot.after {
    background: var(--accent);
  }

  .ba-item p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
  }

  .ba-item.after p {
    color: var(--text);
  }

  .ba-arrow {
    display: none;
    align-items: center;
    justify-content: center;
    padding-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
  }

  @media (min-width: 768px) {
    .ba-arrow {
      display: flex;
    }
  }

  /* screenshot placeholder */
  .screenshot-placeholder {
    background: var(--chip-bg);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    height: 220px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .screenshot-icon {
    width: 32px;
    height: 32px;
    border: 1.5px solid var(--subtle);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .screenshot-icon-inner {
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--subtle);
    border-radius: 2px;
  }

  .screenshot-caption {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }

  .screenshot-desc {
    font-size: 12px;
    color: var(--muted);
    text-align: center;
    max-width: 240px;
    line-height: 1.6;
  }

  /* hard parts */
  .hard-part {
    display: flex;
    flex-direction: column;
    padding: 1rem 0;
    border-bottom: 0.5px solid var(--border);
  }

  @media (min-width: 768px) {
    .hard-part {
      flex-direction: row;
      align-items: center;
      gap: 1rem;
    }
  }

  .hard-part:last-child {
    border-bottom: none;
  }

  .hard-part-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    min-width: 24px;
    padding-top: 3px;
    flex-shrink: 0;
  }

  .hard-part h4 {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .hard-part p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* outcome */
  .cs-outcome {
    padding: 1.75rem 2rem;
  }

  .cs-outcome h3 {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }

  .cs-outcome p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
  }

  .cs-thoughts {
    border-top: 0.5px solid var(--border);
    padding: 1.75rem 2rem;
  }
  .cs-thoughts p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
  }
</style>

<script>
  document.addEventListener("click", (event) => {
    const button = (event.target as HTMLElement).closest(".project-link");

    if (button instanceof HTMLElement) {
      const id = button.dataset.projectId;
      if (id) toggleCaseStudy(id);
    }
  });

  document.addEventListener("click", (event) => {
    console.log("event target", event.target);
    const button = (event.target as HTMLElement).closest(".cs-close-btn");
    if (button instanceof HTMLElement) {
      const id = button.dataset.projectId;
      console.log("close case btn", id);
      if (id) closeCaseStudy(id);
    }
  });

  function openCaseStudy(id: string) {
    const panel = document.getElementById(`case-study-${id}`);
    const trigger = document.getElementById(`${id}-trigger`);
    if (!panel) return;

    // ── mock fetch — comment out and replace with real endpoint ──
    // fetch(`/api/case-studies/${id}`)
    //   .then((res) => res.json())
    //   .then((data) => console.log("case study data:", data));
    // ─────────────────────────────────────────────────────────────

    panel.classList.add("open");
    if (trigger) {
      trigger.textContent = "close ✕";
      const projectItem = trigger.closest(".project-item");
      if (projectItem) {
        const chips = projectItem.querySelectorAll(".chip");
        if (chips) chips.forEach((chip) => chip.classList.add("cs-open"));
        projectItem.classList.add("cs-open");
      }
    }
  }

  function closeCaseStudy(id: string) {
    const panel = document.getElementById(`case-study-${id}`);
    const trigger = document.getElementById(`${id}-trigger`);
    if (!panel) return;

    console.log(panel);
    panel.classList.remove("open");
    if (trigger) {
      trigger.textContent = "case study ↗";
      const projectItem = trigger.closest(".project-item");

      if (projectItem) {
        const chips = projectItem.querySelectorAll(".chip");
        if (chips) chips.forEach((chip) => chip.classList.remove("cs-open"));
        projectItem.classList.remove("cs-open");
        projectItem.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
  }

  function toggleCaseStudy(id: string) {
    const panel = document.getElementById(`case-study-${id}`);
    if (!panel) return;
    panel.classList.contains("open") ? closeCaseStudy(id) : openCaseStudy(id);
  }

  // (window as any).openCaseStudy = openCaseStudy;
  // (window as any).closeCaseStudy = closeCaseStudy;
  // (window as any).toggleCaseStudy = toggleCaseStudy;
</script>

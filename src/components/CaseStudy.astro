---
interface Props {
  projectId: string;
}

const { projectId } = Astro.props;
---

<div class="cs-wrapper">
  <div class="case-study" id={`case-study-${projectId}`}>
    <div class="cs-meta-grid">
      <div class="cs-meta-card">
        <span class="cs-meta-label">ROLE</span>
        <span class="cs-meta-value">Frontend engineer</span>
        <span class="cs-meta-sub">sole frontend owner</span>
      </div>
      <div class="cs-meta-card">
        <span class="cs-meta-label">STACK</span>
        <span class="cs-meta-value">SvelteKit + TypeScript</span>
        <span class="cs-meta-sub">connectrpc · protobuf</span>
      </div>
      <div class="cs-meta-card">
        <span class="cs-meta-label">OUTCOME</span>
        <span class="cs-meta-value">Days → minutes</span>
        <span class="cs-meta-sub">campaign launch time</span>
      </div>
    </div>

    <div class="cs-body">
      <span class="section-label">// the problem</span>
      <p>
        Campaign managers at Fetch were building and launching campaigns
        manually — no dedicated tooling, no shared process. Work lived in
        spreadsheets, handoffs were fragile, and every launch took days of
        coordination.
      </p>
      <p>
        This wasn't a tooling problem waiting to be solved. It was a business
        constraint actively slowing growth.
      </p>
    </div>

    <div class="before-after">
      <div class="ba-card">
        <span class="ba-label before">BEFORE</span>
        <div class="ba-item">
          <div class="ba-dot before"></div><p>
            Manual data entry across spreadsheets
          </p>
        </div>
        <div class="ba-item">
          <div class="ba-dot before"></div><p>Fragile handoffs between teams</p>
        </div>
        <div class="ba-item">
          <div class="ba-dot before"></div><p>
            Days to launch a single campaign
          </p>
        </div>
        <div class="ba-item">
          <div class="ba-dot before"></div><p>No audit trail or history</p>
        </div>
      </div>
      <div class="ba-arrow">→</div>
      <div class="ba-card">
        <span class="ba-label after">AFTER</span>
        <div class="ba-item after">
          <div class="ba-dot after"></div><p>
            Guided multi-step campaign builder
          </p>
        </div>
        <div class="ba-item after">
          <div class="ba-dot after"></div><p>
            Single source of truth for all campaigns
          </p>
        </div>
        <div class="ba-item after">
          <div class="ba-dot after"></div><p>
            Minutes to launch, zero regressions
          </p>
        </div>
        <div class="ba-item after">
          <div class="ba-dot after"></div><p>
            Full history and status visibility
          </p>
        </div>
      </div>
    </div>

    <div class="cs-body">
      <span class="section-label">// screenshot</span>
      <div class="screenshot-placeholder">
        <div class="screenshot-icon">
          <div class="screenshot-icon-inner"></div>
        </div>
        <p class="screenshot-caption">redacted screenshot</p>
        <p class="screenshot-desc">
          campaign builder — step 2 of 4<br />details blurred for
          confidentiality
        </p>
      </div>
    </div>

    <div class="cs-body">
      <span class="section-label">// the hard parts</span>
      <div class="hard-part">
        <span class="hard-part-num">01</span>
        <div>
          <h4>Form state that actually held together</h4>
          <p>
            Campaign creation was a multi-step flow with deeply interdependent
            fields — change the campaign type on step one and half of steps two
            and three needed to adapt. Getting that state model right without
            leaking complexity into the UI took more care than anything else on
            this project.
          </p>
        </div>
      </div>
      <div class="hard-part">
        <span class="hard-part-num">02</span>
        <div>
          <h4>Shaping the API, not just consuming it</h4>
          <p>
            There was no existing backend to build against. I worked closely
            with the backend engineer to define the contracts — advocating for
            shapes that made the UI straightforward rather than adapting to
            whatever was easiest server-side. That collaboration made the
            difference between a clean frontend and a messy one.
          </p>
        </div>
      </div>
      <div class="hard-part">
        <span class="hard-part-num">03</span>
        <div>
          <h4>No prior art to lean on</h4>
          <p>
            Nothing like this existed internally. Every architectural decision
            was a first draft — component structure, data flow, error handling
            patterns. I kept it conservative: fewer abstractions, more readable
            code. The next engineer who touches it should feel relief, not
            dread.
          </p>
        </div>
      </div>
    </div>

    <div class="cs-outcome">
      <span class="section-label">// outcome</span>
      <h3>
        Campaign launch time went from days to minutes. The tool is still in
        use.
      </h3>
      <p>
        No regressions at go-live. The campaign managers who used it stopped
        asking engineering for help with every launch — which was the whole
        point.
      </p>
    </div>
    <div class="cs-close-row">
      <button class="cs-close-btn" data-project-id={projectId}>↑ close</button>
    </div>
  </div>
</div>

<style>
  .case-study {
    display: none;
    background: var(--bg-white);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    margin-top: 1rem;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .case-study.open {
    display: block;
    border-top: 0.5px solid var(--border);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    margin-top: 0;
  }

  .cs-close-row {
    display: flex;
    justify-content: center;
    padding: 0.75rem 2rem;
    border-top: 0.5px solid var(--border);
  }

  .cs-close-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .cs-close-btn:hover {
    color: var(--accent-hover);
  }

  .cs-meta-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
    padding: 1.5rem 2rem;
    border-bottom: 0.5px solid var(--border);
  }

  .cs-meta-card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
  }

  .cs-meta-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }

  .cs-meta-value {
    display: block;
    font-size: 13px;
    font-weight: 500;
  }

  .cs-meta-sub {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 3px;
  }

  .cs-body {
    padding: 1.75rem 2rem;
    border-bottom: 0.5px solid var(--border);
  }

  .cs-body p {
    font-size: 14px;
    line-height: 1.8;
    max-width: 560px;
  }

  .cs-body p + p {
    margin-top: 0.75rem;
  }

  .section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  /* before/after */
  .before-after {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 32px minmax(0, 1fr);
    align-items: start;
    padding: 1.75rem 2rem;
    border-bottom: 0.5px solid var(--border);
  }

  .ba-card {
    background: var(--bg-white);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
  }

  .ba-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    margin-bottom: 10px;
  }

  .ba-label.before {
    color: #a32d2d;
  }
  .ba-label.after {
    color: #3b6d11;
  }

  body.matrix-mode .ba-label.before {
    color: var(--subtle);
  }
  body.matrix-mode .ba-label.after {
    color: var(--accent);
  }

  .ba-item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 8px;
  }

  .ba-item:last-child {
    margin-bottom: 0;
  }

  .ba-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    margin-top: 6px;
    flex-shrink: 0;
  }

  .ba-dot.before {
    background: var(--border);
  }
  .ba-dot.after {
    background: var(--accent);
  }

  .ba-item p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .ba-item.after p {
    color: var(--text);
  }

  .ba-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
  }

  /* screenshot placeholder */
  .screenshot-placeholder {
    background: var(--chip-bg);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    height: 220px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .screenshot-icon {
    width: 32px;
    height: 32px;
    border: 1.5px solid var(--subtle);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .screenshot-icon-inner {
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--subtle);
    border-radius: 2px;
  }

  .screenshot-caption {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }

  .screenshot-desc {
    font-size: 12px;
    color: var(--muted);
    text-align: center;
    max-width: 240px;
    line-height: 1.6;
  }

  /* hard parts */
  .hard-part {
    display: flex;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 0.5px solid var(--border);
  }

  .hard-part:last-child {
    border-bottom: none;
  }

  .hard-part-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    min-width: 24px;
    padding-top: 3px;
    flex-shrink: 0;
  }

  .hard-part h4 {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .hard-part p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* outcome */
  .cs-outcome {
    padding: 1.75rem 2rem;
  }

  .cs-outcome h3 {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.4;
    max-width: 480px;
    margin-bottom: 0.75rem;
  }

  .cs-outcome p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
    max-width: 480px;
  }
</style>

<script>
  document.addEventListener("click", (event) => {
    const button = (event.target as HTMLElement).closest(".project-link");
    if (button instanceof HTMLElement) {
      const id = button.dataset.projectId;
      if (id) toggleCaseStudy(id);
    }
  });

  document.addEventListener("click", (event) => {
    const button = (event.target as HTMLElement).closest(".cs-close-btn");
    if (button instanceof HTMLElement) {
      const id = button.dataset.projectId;
      if (id) closeCaseStudy(id);
    }
  });

  function openCaseStudy(id: string) {
    const panel = document.getElementById(`case-study-${id}`);
    const trigger = document.getElementById(`${id}-trigger`);
    if (!panel) return;

    // ── mock fetch — comment out and replace with real endpoint ──
    // fetch(`/api/case-studies/${id}`)
    //   .then((res) => res.json())
    //   .then((data) => console.log("case study data:", data));
    // ─────────────────────────────────────────────────────────────

    panel.classList.add("open");
    if (trigger) {
      trigger.textContent = "close ✕";
      const projectItem = trigger.closest(".project-item");
      console.log("open", projectItem);
      if (projectItem) {
        const chips = projectItem.querySelectorAll(".chip");
        if (chips) chips.forEach((chip) => chip.classList.add("cs-open"));
        projectItem.classList.add("cs-open");
      }
    }
  }

  function closeCaseStudy(id: string) {
    const panel = document.getElementById(`case-study-${id}`);
    const trigger = document.getElementById(`${id}-trigger`);
    if (!panel) return;

    panel.classList.remove("open");
    if (trigger) {
      trigger.textContent = "case study ↗";
      const projectItem = trigger.closest(".project-item");
      if (projectItem) {
        const chips = projectItem.querySelectorAll(".chip");
        console.log("chips", chips);
        if (chips) chips.forEach((chip) => chip.classList.remove("cs-open"));
        projectItem.classList.remove("cs-open");
        projectItem.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
  }

  function toggleCaseStudy(id: string) {
    const panel = document.getElementById(`case-study-${id}`);
    if (!panel) return;
    panel.classList.contains("open") ? closeCaseStudy(id) : openCaseStudy(id);
  }
</script>

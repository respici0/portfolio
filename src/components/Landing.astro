---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio — Design Reference</title>
    <style>
      /* ─── SECTION LABEL ─── */
      .section-label {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--accent);
        letter-spacing: 0.08em;
        margin-bottom: 1.75rem;
      }

      /* ─── HERO ─── */
      .hero {
        padding: 4.5rem 2rem 3.5rem;
        border-bottom: 0.5px solid var(--border);
        max-width: 720px;
        margin: 0 auto;
      }

      .hero-eyebrow {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 0.06em;
        margin-bottom: 1.25rem;
      }

      .hero h1 {
        font-size: 36px;
        font-weight: 500;
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin-bottom: 1.5rem;
        max-width: 560px;
      }

      .hero p {
        font-size: 16px;
        color: var(--muted);
        line-height: 1.75;
        max-width: 460px;
        margin-bottom: 2rem;
      }

      .hero-cta {
        display: flex;
        gap: 0.75rem;
        align-items: center;
      }

      .btn-primary {
        background: var(--text);
        color: var(--bg);
        font-size: 13px;
        font-family: var(--font-sans);
        padding: 9px 18px;
        border-radius: var(--radius-md);
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
      }

      .btn-secondary {
        background: none;
        color: var(--muted);
        font-size: 13px;
        font-family: var(--font-sans);
        padding: 9px 18px;
        border-radius: var(--radius-md);
        border: 0.5px solid var(--subtle);
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
      }

      .btn-secondary:hover {
        color: var(--text);
        border-color: var(--muted);
      }

      /* ─── SECTION WRAPPER ─── */
      .section {
        padding: 2.5rem 2rem;
        border-bottom: 0.5px solid var(--border);
        max-width: 720px;
        margin: 0 auto;
      }

      /* ─── PROJECTS ─── */
      .project-row {
        padding: 1.5rem 0;
        border-bottom: 0.5px solid var(--border);
        cursor: pointer;
      }

      .project-row:last-child {
        border-bottom: none;
      }

      .project-meta {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.6rem;
      }

      .project-meta-left {
        display: flex;
        gap: 8px;
        align-items: center;
      }

      .tag {
        font-family: var(--font-mono);
        font-size: 11px;
        background: var(--chip-bg);
        color: var(--accent-dark);
        padding: 2px 8px;
        border-radius: var(--radius-sm);
      }

      .project-year {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--muted);
      }

      .project-link {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--accent);
        text-decoration: none;
        cursor: pointer;
      }

      .project-title {
        font-size: 17px;
        font-weight: 500;
        margin-bottom: 0.5rem;
      }

      .project-desc {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.65;
        max-width: 480px;
        margin-bottom: 1rem;
      }

      .chip-row {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }

      .chip {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--muted);
        background: var(--chip-bg);
        padding: 2px 8px;
        border-radius: var(--radius-sm);
      }

      /* ─── CASE STUDY (inline expansion) ─── */
      .case-study {
        display: none;
        background: var(--bg-white);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-lg);
        margin-top: 1rem;
        overflow: hidden;
      }

      .case-study.open {
        display: block;
      }

      .cs-header {
        padding: 2.5rem 2rem 2rem;
        border-bottom: 0.5px solid var(--border);
      }

      .cs-header h2 {
        font-size: 22px;
        font-weight: 500;
        letter-spacing: -0.025em;
        line-height: 1.2;
        margin-bottom: 0.75rem;
      }

      .cs-header p {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.75;
        max-width: 480px;
      }

      .cs-meta-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
        padding: 1.5rem 2rem;
        border-bottom: 0.5px solid var(--border);
      }

      .cs-meta-card {
        background: var(--bg);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-md);
        padding: 0.875rem 1rem;
      }

      .cs-meta-label {
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--muted);
        letter-spacing: 0.06em;
        margin-bottom: 6px;
      }

      .cs-meta-value {
        font-size: 13px;
        font-weight: 500;
      }

      .cs-meta-sub {
        font-size: 12px;
        color: var(--muted);
        margin-top: 3px;
      }

      .cs-body {
        padding: 1.75rem 2rem;
        border-bottom: 0.5px solid var(--border);
      }

      .cs-body p {
        font-size: 14px;
        line-height: 1.8;
        max-width: 560px;
      }

      .cs-body p + p {
        margin-top: 0.75rem;
      }

      /* before/after */
      .before-after {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 32px minmax(0, 1fr);
        align-items: start;
        padding: 1.75rem 2rem;
        border-bottom: 0.5px solid var(--border);
      }

      .ba-card {
        background: var(--bg-white);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-md);
        padding: 1rem;
      }

      .ba-label {
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.06em;
        margin-bottom: 10px;
      }

      .ba-label.before {
        color: #a32d2d;
      }
      .ba-label.after {
        color: #3b6d11;
      }

      .ba-item {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 8px;
      }

      .ba-item:last-child {
        margin-bottom: 0;
      }

      .ba-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        margin-top: 6px;
        flex-shrink: 0;
      }

      .ba-dot.before {
        background: var(--border);
      }
      .ba-dot.after {
        background: var(--accent);
      }

      .ba-item p {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.6;
      }

      .ba-item.after p {
        color: var(--text);
      }

      .ba-arrow {
        display: flex;
        align-items: center;
        justify-content: center;
        padding-top: 2.5rem;
        font-family: var(--font-mono);
        font-size: 14px;
        color: var(--accent);
      }

      /* screenshot placeholder */
      .screenshot-placeholder {
        background: #f0ebe3;
        border: 0.5px solid var(--border);
        border-radius: var(--radius-md);
        height: 220px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
      }

      .screenshot-icon {
        width: 32px;
        height: 32px;
        border: 1.5px solid var(--subtle);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .screenshot-icon-inner {
        width: 14px;
        height: 14px;
        border: 1.5px solid var(--subtle);
        border-radius: 2px;
      }

      /* hard parts */
      .hard-part {
        display: flex;
        gap: 1.5rem;
        padding: 1rem 0;
        border-bottom: 0.5px solid var(--border);
      }

      .hard-part:last-child {
        border-bottom: none;
      }

      .hard-part-num {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--subtle);
        min-width: 24px;
        padding-top: 3px;
        flex-shrink: 0;
      }

      .hard-part h4 {
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 4px;
      }

      .hard-part p {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.7;
      }

      /* outcome */
      .cs-outcome {
        padding: 1.75rem 2rem;
      }

      .cs-outcome h3 {
        font-size: 20px;
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.4;
        max-width: 480px;
        margin-bottom: 0.75rem;
      }

      .cs-outcome p {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.75;
        max-width: 480px;
      }

      /* ─── HOW I WORK ─── */
      .how-item {
        display: flex;
        gap: 1.5rem;
        align-items: flex-start;
        padding: 1rem 0;
        border-bottom: 0.5px solid var(--border);
      }

      .how-item:last-child {
        border-bottom: none;
      }

      .how-num {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--subtle);
        min-width: 24px;
        padding-top: 3px;
        flex-shrink: 0;
      }

      .how-item p {
        font-size: 14px;
        line-height: 1.7;
      }

      /* ─── ABOUT GRID ─── */
      .about-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
      }

      .about-card {
        background: var(--bg-white);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1rem 1.25rem;
      }

      .about-label {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 4px;
      }

      .about-val {
        font-size: 14px;
        font-weight: 500;
      }

      /* ─── STACK ─── */
      .stack-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
      }

      .stack-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        background: var(--bg-white);
        border: 0.5px solid var(--border);
        border-radius: var(--radius-md);
      }

      .stack-name {
        font-size: 13px;
      }

      .stack-level {
        font-family: var(--font-mono);
        font-size: 10px;
      }

      .stack-level.primary {
        color: var(--accent);
      }
      .stack-level.proficient {
        color: var(--muted);
      }
      .stack-level.growing {
        color: var(--subtle);
      }

      /* ─── CONTACT ─── */
      .contact-section {
        padding: 2.5rem 2rem 4rem;
        max-width: 720px;
        margin: 0 auto;
      }

      .contact-section h2 {
        font-size: 24px;
        font-weight: 500;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .contact-section p {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.7;
        max-width: 400px;
        margin-bottom: 1.5rem;
      }

      .contact-email {
        font-family: var(--font-mono);
        font-size: 14px;
        color: var(--accent);
        text-decoration: none;
      }

      .contact-email:hover {
        text-decoration: underline;
      }

      /* ─── DESIGN NOTE ─── */
      .design-note {
        text-align: center;
        padding: 1.5rem 2rem;
        border-top: 0.5px solid var(--border);
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--subtle);
        max-width: 720px;
        margin: 0 auto;
      }
    </style>
  </head>
  <body>
    <Nav />
    <!-- HERO -->
    <section class="hero">
      <p class="hero-eyebrow">PORTLAND, OR — AVAILABLE</p>
      <h1>
        I close the gap between design and production — without cutting corners.
      </h1>
      <p>
        7 years building frontend at product companies. I care about what ships
        and how well it's built. Usually both at the same time.
      </p>
      <div class="hero-cta">
        <a href="#work" class="btn-primary">View my work</a>
        <a href="#" class="btn-secondary">Resume</a>
      </div>
    </section>

    <!-- WORK -->
    <section class="section" id="work">
      <p class="section-label">// selected work</p>

      <!-- <div class="project-row" onclick="toggleCaseStudy('fetch')"> -->
      <div class="project-row">
        <div class="project-meta">
          <div class="project-meta-left">
            <span class="tag">Fetch Rewards</span>
            <span class="project-year">2022 — 2024</span>
          </div>
          <span class="project-link" id="fetch-toggle">case study ↗</span>
        </div>
        <p class="project-title">Campaign Management Dashboard</p>
        <p class="project-desc">
          Owned frontend architecture from scratch. Campaign launch time dropped
          from days to minutes — zero regressions at go-live.
        </p>
        <div class="chip-row">
          <span class="chip">Svelte</span>
          <span class="chip">TypeScript</span>
          <span class="chip">REST API</span>
        </div>

        <!-- CASE STUDY EXPANSION -->
        <div class="case-study" id="case-study-fetch">
          <div class="cs-header">
            <div
              style="display:flex;gap:8px;margin-bottom:1.25rem;align-items:center;"
            >
              <span class="tag">Fetch Rewards</span>
              <span class="mono muted" style="font-size:11px;">2022 — 2024</span
              >
            </div>
            <h2>Campaign Management Dashboard</h2>
            <p>
              Replacing a manual, spreadsheet-driven process with a
              purpose-built internal tool — and getting it right the first time.
            </p>
          </div>

          <div class="cs-meta-grid">
            <div class="cs-meta-card">
              <p class="cs-meta-label">ROLE</p>
              <p class="cs-meta-value">Frontend engineer</p>
              <p class="cs-meta-sub">sole frontend owner</p>
            </div>
            <div class="cs-meta-card">
              <p class="cs-meta-label">STACK</p>
              <p class="cs-meta-value">Svelte + TypeScript</p>
              <p class="cs-meta-sub">REST API</p>
            </div>
            <div class="cs-meta-card">
              <p class="cs-meta-label">OUTCOME</p>
              <p class="cs-meta-value">Days → minutes</p>
              <p class="cs-meta-sub">campaign launch time</p>
            </div>
          </div>

          <div class="cs-body">
            <p class="section-label">// the problem</p>
            <p>
              Campaign managers at Fetch were building and launching campaigns
              manually — no dedicated tooling, no shared process. Work lived in
              spreadsheets, handoffs were fragile, and every launch took days of
              coordination.
            </p>
            <p style="color:var(--muted);">
              This wasn't a tooling problem waiting to be solved. It was a
              business constraint actively slowing growth.
            </p>
          </div>

          <div class="before-after">
            <div class="ba-card">
              <p class="ba-label before">BEFORE</p>
              <div class="ba-item">
                <div class="ba-dot before"></div>
                <p>Manual data entry across spreadsheets</p>
              </div>
              <div class="ba-item">
                <div class="ba-dot before"></div>
                <p>Fragile handoffs between teams</p>
              </div>
              <div class="ba-item">
                <div class="ba-dot before"></div>
                <p>Days to launch a single campaign</p>
              </div>
              <div class="ba-item">
                <div class="ba-dot before"></div>
                <p>No audit trail or history</p>
              </div>
            </div>
            <div class="ba-arrow">→</div>
            <div class="ba-card">
              <p class="ba-label after">AFTER</p>
              <div class="ba-item after">
                <div class="ba-dot after"></div>
                <p>Guided multi-step campaign builder</p>
              </div>
              <div class="ba-item after">
                <div class="ba-dot after"></div>
                <p>Single source of truth for all campaigns</p>
              </div>
              <div class="ba-item after">
                <div class="ba-dot after"></div>
                <p>Minutes to launch, zero regressions</p>
              </div>
              <div class="ba-item after">
                <div class="ba-dot after"></div>
                <p>Full history and status visibility</p>
              </div>
            </div>
          </div>

          <div class="cs-body">
            <p class="section-label">// screenshot</p>
            <div class="screenshot-placeholder">
              <div class="screenshot-icon">
                <div class="screenshot-icon-inner"></div>
              </div>
              <p class="mono muted" style="font-size:11px;">
                redacted screenshot
              </p>
              <p
                class="muted"
                style="font-size:12px;text-align:center;max-width:240px;line-height:1.6;"
              >
                campaign builder — step 2 of 4<br />details blurred for
                confidentiality
              </p>
            </div>
          </div>

          <div class="cs-body">
            <p class="section-label">// the hard parts</p>
            <div class="hard-part">
              <span class="hard-part-num">01</span>
              <div>
                <h4>Form state that actually held together</h4>
                <p>
                  Campaign creation was a multi-step flow with deeply
                  interdependent fields — change the campaign type on step one
                  and half of steps two and three needed to adapt. Getting that
                  state model right without leaking complexity into the UI took
                  more care than anything else on this project.
                </p>
              </div>
            </div>
            <div class="hard-part">
              <span class="hard-part-num">02</span>
              <div>
                <h4>Shaping the API, not just consuming it</h4>
                <p>
                  There was no existing backend to build against. I worked
                  closely with the backend engineer to define the contracts —
                  advocating for shapes that made the UI straightforward rather
                  than adapting to whatever was easiest server-side. That
                  collaboration made the difference between a clean frontend and
                  a messy one.
                </p>
              </div>
            </div>
            <div class="hard-part">
              <span class="hard-part-num">03</span>
              <div>
                <h4>No prior art to lean on</h4>
                <p>
                  Nothing like this existed internally. Every architectural
                  decision was a first draft — component structure, data flow,
                  error handling patterns. I kept it conservative: fewer
                  abstractions, more readable code. The next engineer who
                  touches it should feel relief, not dread.
                </p>
              </div>
            </div>
          </div>

          <div class="cs-outcome">
            <p class="section-label">// outcome</p>
            <h3>
              Campaign launch time went from days to minutes. The tool is still
              in use.
            </h3>
            <p>
              No regressions at go-live. The campaign managers who used it
              stopped asking engineering for help with every launch — which was
              the whole point.
            </p>
          </div>
        </div>
      </div>

      <div class="project-row">
        <div class="project-meta">
          <div class="project-meta-left">
            <span class="tag">Side project</span>
            <span class="project-year">2025</span>
          </div>
          <span class="project-link">live ↗</span>
        </div>
        <p class="project-title">Job Application Tracker</p>
        <p class="project-desc">
          Full-stack with a friend. Auth, data layer, and UI built from the
          ground up — my first serious backend work.
        </p>
        <div class="chip-row">
          <span class="chip">Next.js</span>
          <span class="chip">MongoDB</span>
          <span class="chip">Better Auth</span>
          <span class="chip">shadcn</span>
        </div>
      </div>
    </section>

    <!-- HOW I WORK -->
    <section class="section">
      <p class="section-label">// how I work</p>
      <div class="how-item">
        <span class="how-num">01</span>
        <p>
          I treat performance as a feature, not a last-minute audit. Bundle
          size, render cost, and load time are part of the design.
        </p>
      </div>
      <div class="how-item">
        <span class="how-num">02</span>
        <p>
          I push back on designs that don't hold up at edge cases — then I build
          exactly what we agreed on.
        </p>
      </div>
      <div class="how-item">
        <span class="how-num">03</span>
        <p>
          I prefer fewer, well-chosen abstractions over clever code. The next
          engineer who touches this should feel relief, not dread.
        </p>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="section" id="about">
      <p class="section-label">// about</p>
      <div class="about-grid">
        <div class="about-card">
          <p class="about-label">based in</p>
          <p class="about-val">Portland, OR</p>
        </div>
        <div class="about-card">
          <p class="about-label">experience</p>
          <p class="about-val">7 years</p>
        </div>
        <div class="about-card">
          <p class="about-label">focus</p>
          <p class="about-val">Frontend → Fullstack</p>
        </div>
        <div class="about-card">
          <p class="about-label">open to</p>
          <p class="about-val">Hybrid or remote</p>
        </div>
      </div>
    </section>

    <!-- STACK -->
    <section class="section">
      <p class="section-label">// stack</p>
      <div class="stack-grid">
        <div class="stack-item">
          <span class="stack-name">React / Next.js</span>
          <span class="stack-level primary">primary</span>
        </div>
        <div class="stack-item">
          <span class="stack-name">TypeScript</span>
          <span class="stack-level primary">primary</span>
        </div>
        <div class="stack-item">
          <span class="stack-name">Svelte</span>
          <span class="stack-level proficient">proficient</span>
        </div>
        <div class="stack-item">
          <span class="stack-name">Tailwind CSS</span>
          <span class="stack-level proficient">proficient</span>
        </div>
        <div class="stack-item">
          <span class="stack-name">Node.js</span>
          <span class="stack-level growing">growing</span>
        </div>
        <div class="stack-item">
          <span class="stack-name">MongoDB</span>
          <span class="stack-level growing">growing</span>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="contact-section" id="contact">
      <p class="section-label">// get in touch</p>
      <h2>Let's work together.</h2>

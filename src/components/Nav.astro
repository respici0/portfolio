---
import WhiteRabbit from "./icons/WhiteRabbit.astro";
import BluePill from "./icons/BluePill.astro";

type NavItem = {
  href: string;
  name: string;
};

const navItems: NavItem[] = [
  {
    href: "#work",
    name: "work",
  },
  {
    href: "#about",
    name: "about",
  },
  {
    href: "#think",
    name: "think",
  },
  {
    href: "#stack",
    name: "stack",
  },
  {
    href: "#connect",
    name: "connect",
  },
];
---

<nav>
  <div class="nav-inner">
    <div class="nav-logo-wrap">
      <span class="nav-logo">respicio.dev</span>
      <button
        id="rabbit-header"
        class="rabbit-btn"
        aria-label="Follow the white rabbit"
        title="Follow the white rabbit"
      >
        <span class="rabbit-svg">
          <WhiteRabbit />
        </span>

        <span class="pill-svg">
          <BluePill />
        </span>
      </button>
    </div>

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="nav-links" id="nav-links">
      {
        navItems.map((item: NavItem) => (
          <li>
            <a href={item.href}>{item.name}</a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const hamburger = document.getElementById("hamburger")!;
  const navLinks = document.getElementById("nav-links")!;

  hamburger.addEventListener("click", () => {
    const isOpen = navLinks.classList.toggle("open");
    hamburger.setAttribute("aria-expanded", String(isOpen));
  });

  navLinks.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      navLinks.classList.remove("open");
      hamburger.setAttribute("aria-expanded", "false");
    });
  });

  window.addEventListener("click", (e) => {
    if (
      !navLinks.contains(e.target as Node) &&
      !hamburger.contains(e.target as Node)
    ) {
      navLinks.classList.remove("open");
      hamburger.setAttribute("aria-expanded", "false");
    }
  });
</script>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2rem;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    border-bottom: 0.5px solid var(--border);
  }

  .nav-logo-wrap {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  .rabbit {
    background: none;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    color: var(--subtle);
    opacity: 0.4;
    transition: opacity 0.25s;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 24px;
    height: 24px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--text);
    transition: opacity 0.2s;
  }

  .nav-links {
    display: none;
    flex-direction: column;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
    position: absolute;
    top: 100%;
    right: 1.5rem;
    background: var(--bg-white);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    min-width: fit-content;
    z-index: 100;
    overflow: hidden;
  }

  .nav-links.open {
    display: flex;
  }

  .nav-links li a {
    display: block;
    padding: 0.65rem 1rem;
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    margin: 0;
  }

  .nav-links li + li {
    border-top: 0.5px solid var(--border);
  }
  .nav-links a:hover {
    color: var(--text);
  }

  @media (min-width: 768px) {
    .hamburger {
      display: none;
    }

    .nav-links {
      display: flex;
      flex-direction: row;
      position: static;
      background: none;
      border: none;
      border-radius: 0;
      min-width: unset;
      gap: 1.5rem;
    }

    .nav-links li + li {
      border-top: none;
    }

    .nav-links li a {
      padding: 0;
    }

    .nav-links li a:hover {
      padding: 0;
      color: var(--text);
    }
  }
</style>

---
import type { AstroComponentFactory } from "astro/runtime/server/render/astro/index.js";
import Github from "./icons/Github.astro";
import LinkedIn from "./icons/LinkedIn.astro";

type Link = {
  href: string;
  cls: string;
  "aria-label": string;
  icon: AstroComponentFactory;
};

const links: Link[] = [
  {
    href: "https://github.com/respici0",
    cls: "github",
    "aria-label": "Github",
    icon: Github,
  },
  {
    href: "https://linkedin.com/in/respici0",
    cls: "linkedIn",
    "aria-label": "LinkedIn",
    icon: LinkedIn,
  },
];
---

<section class="contact-section" id="contact">
  <span class="contact-label">// let's connect</span>
  <h3>and build something wonderful.</h3>
  <p>
    I'm open to full-time roles. If something looks interesting, I'd love to
    hear about it.
  </p>
  <div class="link-cta">
    <a href="mailto:respicio.robert@gmail.com" class="contact-email"
      >say hello ↗</a
    >
    <div style="width:0.5px;height:20px;background:#b9b3ab;"></div>
    <div style="display:flex;gap:1rem;align-items:center;"></div>
    {
      links.map(({ href, cls, "aria-label": label, icon: Icon }: Link) => (
        <a {href} target="_blank" class={cls} aria-label={label}>
          <Icon />
        </a>
      ))
    }
  </div>

  <style>
    .contact-section {
      padding: 2.5rem 2rem 4rem;
      max-width: 720px;
      margin: 0 auto;
    }

    .contact-label {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--accent);
      letter-spacing: 0.08em;
      margin-bottom: 1rem;
    }

    .contact-section h3 {
      font-size: 24px;
      font-weight: 500;
      letter-spacing: -0.02em;
      margin-bottom: 0.75rem;
    }

    .contact-section p {
      font-size: 14px;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }

    .contact-email {
      font-family: var(--font-mono);
      font-size: 14px;
      color: var(--accent);
      text-decoration: none;
    }

    .contact-email:hover {
      color: var(--accent-hover);
      text-decoration: underline;
    }

    .link-cta {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .github,
    .linkedIn {
      color: var(--muted);
      display: flex;
      align-items: center;
    }

    .github:hover {
      color: #24292f;
    }

    .linkedIn:hover {
      color: #0a66c2;
    }
  </style>
</section>
